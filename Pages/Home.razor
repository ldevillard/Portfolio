@page "/"
@using Portfolio.Components

<MudContainer MaxWidth="MaxWidth.Large" Class="py-12">

    <MudStack Spacing="8" AlignItems="AlignItems.Center">

        <MudPaper Class="presentation-section pa-8 pa-md-12" Elevation="0">
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                <MudStack Row="true"
                          Spacing="3"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.Center"
                          Class="presentation-header">

                    <MudText Typo="Typo.h3" Align="Align.Center" Class="presentation-title">
                        Hi, I'm <span class="presentation-highlight">Logan Devillard</span>
                    </MudText>

                    <img src="images/profile.png" alt="Logan Devillard" class="profile-picture" />
                </MudStack>

                <MudText Typo="Typo.body1" Align="Align.Center" Class="presentation-description">
                    My name is Logan Devillard. I'm from a small town next to Lyon in France 🇫🇷.
                    I studied computer programming at
                    <a href="https://42lyon.fr/" target="_blank" rel="noopener noreferrer">42 Lyon</a>
                    and I’m currently working as an Engine Programmer position at
                    <a href="https://www.virtuosgames.com/" target="_blank" rel="noopener noreferrer">Virtuos Montpellier</a>
                    on AAA game development 🕹️.
                    <br /><br />
                    I have a strong interest in engine, rendering, and low-level systems.
                    I enjoy building personal projects and sharing what I learn along the way.
                    If anything on this site can help, inspire, or be useful to someone else, then that already means a lot to me 🚀.
                </MudText>
            </MudStack>
        </MudPaper>

        <!-- SOCIAL / QUICK LINKS -->
        <MudPaper Class="social-strip pa-4" Elevation="0">
            <MudStack Row="true" Spacing="2" Justify="Justify.Center" Class="flex-wrap">
                <MudChip T="string"
                         Clickable="true"
                         Href="https://github.com/ldevillard"
                         Target="_blank"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Custom.Brands.GitHub">
                    GitHub
                </MudChip>

                <MudChip T="string"
                         Clickable="true"
                         Href="https://www.linkedin.com/in/logan-devillard-004971207/"
                         Target="_blank"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Custom.Brands.LinkedIn">
                    LinkedIn
                </MudChip>

                <MudChip T="string"
                         Clickable="true"
                         Href="/articles"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.Article">
                    Articles
                </MudChip>

                <MudChip T="string"
                         Clickable="true"
                         Href="/projects"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.Code">
                    Projects
                </MudChip>

                <MudChip T="string"
                         Clickable="true"
                         Href="mailto:logandvllrd@gmail.com"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.Email">
                    Email
                </MudChip>
            </MudStack>
        </MudPaper>
        
        <Featured/>

        <!-- SECTION TITLE -->
        <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mt-4">
            <MudText Typo="Typo.h4" Align="Align.Center">
                Explore my work
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="section-subtitle">
                A few areas I like to build and share.
            </MudText>
        </MudStack>

        <!-- GRID -->
        <MudGrid Spacing="4" Class="mt-2">

            <MudItem xs="12" sm="6" md="4">
                <a href="/projects" class="content-card-link" aria-label="Open projects page">
                    <MudPaper Class="content-card pa-6 h-100" Elevation="0">
                        <MudText Typo="Typo.h5" Class="mb-3">Projects</MudText>
                        <div class="content-card-media">
                            <img src="images/raytracing.png" alt="Projects showcase" class="content-card-image" />
                        </div>
                        <MudText Typo="Typo.body1" Class="card-text">
                            Personal experiments, engine work, rendering prototypes, and game systems.
                        </MudText>
                    </MudPaper>
                </a>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <a href="/articles" class="content-card-link" aria-label="Open articles page">
                    <MudPaper Class="content-card pa-6 h-100" Elevation="0">
                        <MudText Typo="Typo.h5" Class="mb-3">Articles</MudText>
                        <div class="content-card-media">
                            <img src="images/bvh-showcase.gif" alt="Articles showcase" class="content-card-image" />
                        </div>
                        <MudText Typo="Typo.body1" Class="card-text">
                            Notes, breakdowns, and dev write-ups about graphics, engines, and programming.
                        </MudText>
                    </MudPaper>
                </a>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <a href="/about" class="content-card-link" aria-label="Open about page">
                    <MudPaper Class="content-card pa-6 h-100" Elevation="0">
                        <MudText Typo="Typo.h5" Class="mb-3">About Me</MudText>
                        <div class="content-card-media">
                            <img src="images/profile.png" alt="Profile portrait" class="content-card-image" />
                        </div>
                        <MudText Typo="Typo.body1" Class="card-text">
                            My background, what I enjoy building, and the kind of work I want to do more of.
                        </MudText>
                    </MudPaper>
                </a>
            </MudItem>

        </MudGrid>
    </MudStack>
</MudContainer>
