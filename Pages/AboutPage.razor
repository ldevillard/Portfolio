@page "/about"

<PageTitle>About</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <MudButton Href="/"
               Variant="Variant.Text"
               Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Class="mb-4">
        Back to Home
    </MudButton>

    <MudPaper Class="presentation-section pa-8" Elevation="0">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h3">About Me</MudText>
            <MudText Typo="Typo.body1" Class="presentation-description">
                This page will cover my background, the kind of systems I enjoy building, and the work I want to keep pushing forward.
            </MudText>
        </MudStack>
    </MudPaper>
</MudContainer>
