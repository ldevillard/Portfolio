@page "/"

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <MudStack Spacing="4">
            <MudPaper Class="presentation-section pa-8 pa-md-12" Elevation="0" Outlined="true">
                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                    <MudStack Row="true"
                              Spacing="3"
                              AlignItems="AlignItems.Center"
                              Justify="Justify.Center"
                              Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.h3" Align="Align.Center" Class="presentation-title">
                            Hi, I'm <span class="presentation-highlight">Logan Devillard</span>
                        </MudText>

                        <img src="images/profile.png" alt="Logan Devillard" class="profile-picture" />
                    </MudStack>

                    <MudText Typo="Typo.body1" Class="presentation-description mx-auto" Align="Align.Justify">
                        <br/>
                        My name is Logan Devillard. I'm from a small town next to Lyon in France 🇫🇷.
                        I studied computer programming at
                        <MudLink Href="https://42lyon.fr/" Target="_blank" Color="Color.Secondary">42 Lyon</MudLink>
                        and I’m currently working as an Engine Programmer position at
                        <MudLink Href="https://www.virtuosgames.com/" Target="_blank" Color="Color.Secondary">Virtuos Montpellier</MudLink>
                        on AAA game development 🕹️.
                        <br/><br/>
                        I have a strong interest in engine, rendering, and low-level systems.
                        I enjoy building personal projects and sharing what I learn along the way.
                        If anything on this site can help, inspire, or be useful to someone else, then that already means a lot to me 🚀.
                    </MudText>
                </MudStack>
            </MudPaper>

            <MudPaper Class="social-strip pa-4" Elevation="0" Outlined="true">
                <MudStack Row="true" Spacing="2" Justify="Justify.Center" Wrap="Wrap.Wrap">
                    <MudChip T="string"
                             Href="https://github.com/ldevillard"
                             Target="_blank"
                             Variant="Variant.Outlined"
                             Color="Color.Secondary"
                             Icon="@Icons.Custom.Brands.GitHub">
                        GitHub
                    </MudChip>

                    <MudChip T="string"
                             Href="https://www.linkedin.com/in/logan-devillard-004971207/"
                             Target="_blank"
                             Variant="Variant.Outlined"
                             Color="Color.Secondary"
                             Icon="@Icons.Custom.Brands.LinkedIn">
                        LinkedIn
                    </MudChip>

                    <MudChip T="string"
                             Href="articles"
                             Variant="Variant.Outlined"
                             Color="Color.Secondary"
                             Icon="@Icons.Material.Filled.Article">
                        Articles
                    </MudChip>

                    <MudChip T="string"
                             Href="projects"
                             Variant="Variant.Outlined"
                             Color="Color.Secondary"
                             Icon="@Icons.Material.Filled.Code">
                        Projects
                    </MudChip>

                    <MudChip T="string"
                             Href="mailto:logandvllrd@gmail.com"
                             Variant="Variant.Outlined"
                             Color="Color.Secondary"
                             Icon="@Icons.Material.Filled.Email">
                        Email
                    </MudChip>
                </MudStack>
            </MudPaper>

            <SectionDivider Label="Professional work"
                            Caption="Titles and productions that I had the opportunity to contribute to." />

            <Featured />

            <SectionDivider Label="Personal work"
                            Caption="A few areas I like to build and share." />

            <div class="content-grid">
                <div class="content-grid-item">
                    <MudLink Href="projects" Class="content-card-link" Underline="Underline.None">
                        <MudPaper Class="content-card pa-6 h-100" Elevation="0" Outlined="true">
                            <MudStack Spacing="0" Class="h-100">
                                <MudText Typo="Typo.h5" Class="content-card-title mb-3">Personal projects</MudText>
                                <div class="content-card-media mb-4">
                                    <img src="images/raytracing.png" alt="Projects showcase" class="content-card-image" />
                                </div>
                                <MudText Typo="Typo.body1" Class="card-text" Align="Align.Justify">
                                    Personal experiments, engine work, rendering prototypes, and game systems.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudLink>
                </div>

                <div class="content-grid-item">
                    <MudLink Href="articles" Class="content-card-link" Underline="Underline.None">
                        <MudPaper Class="content-card pa-6 h-100" Elevation="0" Outlined="true">
                            <MudStack Spacing="0" Class="h-100">
                                <MudText Typo="Typo.h5" Class="content-card-title mb-3">Articles</MudText>
                                <div class="content-card-media mb-4">
                                    <img src="images/bvh-showcase.gif" alt="Articles showcase" class="content-card-image" />
                                </div>
                                <MudText Typo="Typo.body1" Class="card-text" Align="Align.Justify">
                                    Notes, breakdowns, and dev write-ups about graphics, engines, and programming.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudLink>
                </div>

                <div class="content-grid-item">
                    <MudLink Href="about" Class="content-card-link" Underline="Underline.None">
                        <MudPaper Class="content-card pa-6 h-100" Elevation="0" Outlined="true">
                            <MudStack Spacing="0" Class="h-100">
                                <MudText Typo="Typo.h5" Class="content-card-title mb-3">About Me</MudText>
                                <div class="content-card-media mb-4">
                                    <img src="images/profile.png" alt="Profile portrait" class="content-card-image" />
                                </div>
                                <MudText Typo="Typo.body1" Class="card-text" Align="Align.Justify">
                                    My background, what I enjoy building, and the kind of work I want to do more of.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudLink>
                </div>
            </div>
    </MudStack>
</MudContainer>
