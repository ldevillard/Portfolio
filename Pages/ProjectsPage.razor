@page "/projects"
@inject NavigationManager Navigation

<PageTitle>Projects</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <MudButton OnClick="@(() => Navigation.NavigateTo(""))"
               Variant="Variant.Text"
               Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Class="mb-4">
        Back to Home
    </MudButton>

    <MudPaper Class="presentation-section pa-8" Elevation="0">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h3">Personal projects</MudText>
            <MudText Typo="Typo.body1" Class="presentation-description">
                This page will collect personal engine work, rendering experiments, prototypes, and game systems.
            </MudText>
        </MudStack>
    </MudPaper>

    <MudStack Spacing="3" Class="mt-6">
        <ProjectCard Title="Ray Tracing Playground"
                     Category="Rendering"
                     Description="A personal rendering sandbox focused on ray tracing, lighting experiments, and acceleration structure work."
                     ImageSrc="images/raytracing.png" />

        <ProjectCard Title="Object Picking Prototype"
                     Category="Engine"
                     Description="A small engine-side prototype around camera rays, scene queries, and object picking workflows."
                     ImageSrc="images/picker.png" />
    </MudStack>
</MudContainer>
