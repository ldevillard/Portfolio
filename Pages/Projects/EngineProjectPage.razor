@page "/projects/3d-engine"
@page "/projects/devil-engine"

<PageTitle>Devil Engine</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <BackHomeButton Text="Back to projects" Href="projects" Class="mb-4" />

    <MudStack Spacing="4">
        <ProjectIntro Title="Devil Engine"
                      Description="A personal C++ / OpenGL engine focused on rendering, editor tooling, scene authoring, and BVH-accelerated ray tracing."
                      ImageSrc="images/editor-showcase.gif" />

        <MudPaper Class="pa-3 rounded-lg" Elevation="0" Outlined="true">
            <MudStack Row="true"
                      Spacing="1"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.FlexStart"
                      Style="flex-wrap: wrap;">
                <MudChip T="string"
                         Href="@RepositoryUrl"
                         Target="_blank"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Custom.Brands.GitHub">
                    GitHub repository
                </MudChip>

                <MudChip T="string"
                         Href="@MousePickingArticleUrl"
                         Target="_blank"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.Article">
                    Related article
                </MudChip>
                    
                <MudChip T="string"
                         Href="https://github.com/ldevillard/Devil-Engine/releases/tag/v0.1"
                         Target="_blank"
                         Variant="Variant.Outlined"
                         Color="Color.Success"
                         Icon="@Icons.Material.Filled.ArrowOutward">
                    Try it out
                </MudChip>

                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="Color.Warning">
                    OpenGL 4.5
                </MudChip>

                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Color="Color.Warning">
                    C++
                </MudChip>
            </MudStack>
        </MudPaper>
        
        <MudPaper Class="pa-6 rounded-lg" Elevation="0" Outlined="true">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">Project Summary and Motivation</MudText>

                <MudDivider/>
                
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body1" Class="mt-3" Align="Align.Left">
                        Devil Engine is a personal rendering engine project built from a strong interest in real-time graphics and a desire to understand how the different parts of an engine fit together.
                    </MudText>

                    <MudText Typo="Typo.body1" Class="mt-3" Align="Align.Left">
                        The goal was not only to build a renderer, but to explore the full workflow around it: scene editing, transform gizmos, object inspection, save and load systems, and an integrated BVH-based ray tracer for more advanced rendering experiments.
                    </MudText>

                    <MudText Typo="Typo.body1" Class="mt-3" Align="Align.Left">
                        This project began as a way to strengthen my knowledge of 3D rendering. It has since become an experimental playground where I can explore new techniques, iterate on ideas, and continue expanding my graphics programming skills.
                    </MudText>
                    <MudPaper Class="pa-3 rounded-lg mt-3" Elevation="0" Outlined="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Left">
                                Next step: I would like to use the engine as a base for future experiments such as fluid simulation.
                            </MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Color="Color.Warning" Size="Size.Small" />
                        </MudStack>
                    </MudPaper>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-6 rounded-lg" Elevation="0" Outlined="true">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">Main Features</MudText>
                <MudDivider/>
                <MudGrid Spacing="2">
                    @foreach (FeatureItem feature in Features)
                    {
                        <MudItem xs="12" md="6" Class="mt-2">
                            <MudStack Spacing="2" Class="engine-project-feature">
                                <MudIcon Icon="@feature.Icon" Color="Color.Warning" Size="Size.Large" />
                                <MudText Typo="Typo.h6">@feature.Title</MudText>
                                <MudText Typo="Typo.body1">@feature.Description</MudText>
                            </MudStack>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-6 rounded-lg" Elevation="0" Outlined="true">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">Challenges</MudText>
                <MudDivider/>
                <MudText Typo="Typo.body1">
                    Here are a few challenges that came up while building the engine. Several of them raised questions I had not really anticipated at the beginning, especially around data layout, runtime reconstruction, and the gap between a rendering feature working in isolation and behaving correctly inside an editor.
                </MudText>
                <MudDivider/>
                <MudGrid Spacing="2">
                    @for (int i = 0; i < _challengeViews.Length; i++)
                    {
                        int index = i;
                        var challenge = _challengeViews[index];
                        string[] restLines = challenge.RestLines ?? Array.Empty<string>();
                        bool isExpanded = _challengeExpanded.Length > index && _challengeExpanded[index];

                        <MudItem xs="12" md="6" Class="mt-2">
                            <MudStack Spacing="2" Class="engine-project-feature">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@challenge.Icon" Color="Color.Warning" Size="Size.Medium" />
                                <MudText Typo="Typo.h6">@challenge.Title</MudText>
                                </MudStack>

                                @if (restLines.Length > 0)
                                {
                                    <MudStack Spacing="0" AlignItems="AlignItems.Start">
                                        <MudText Typo="Typo.body1">@challenge.FirstLine</MudText>
                                        <MudCollapse Expanded="@isExpanded">

                                            @foreach (string line in restLines)
                                            {
                                                <MudText Typo="Typo.body1" Class="mt-2">@line</MudText>
                                            }

                                        </MudCollapse>
                                        <MudButton Variant="Variant.Text"
                                                   Size="Size.Small"
                                                   Class="mt-2"
                                                   Style="margin-left: -5px"
                                                   Color="Color.Secondary"
                                                   OnClick="@(() => ToggleChallenge(index))"
                                                   EndIcon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)">
                                            @GetToggleLabel(index)
                                        </MudButton>
                                    </MudStack>

                                }
                            </MudStack>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </MudPaper>
        
        <MudPaper Class="pa-6 rounded-lg" Elevation="0" Outlined="true">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">Selected Visuals</MudText>
                <MudDivider/>

        <MudGrid Spacing="2">
            @foreach (ShowcaseItem showcase in ShowcaseItems)
            {
                <MudItem xs="12" md="6">
                    <MudStack Spacing="2" Class="engine-project-visual">
                        <img src="@showcase.ImageSrc"
                             alt="@showcase.Title"
                             class="engine-project-image" />
                                <MudText Typo="Typo.h6">@showcase.Title</MudText>
                                <MudText Typo="Typo.body2">@showcase.Description</MudText>
                            </MudStack>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </MudPaper>

        <GithubFooter Href="@RepositoryUrl" />

        <ProjectSources Sources="@Sources" />
    </MudStack>
</MudContainer>
