@page "/projects/chip-8-emulator"

<PageTitle>Chip-8 Emulator</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <BackHomeButton Text="Back to projects" Href="projects" Class="mb-4" />

    <MudStack Spacing="4">
        <ProjectIntro Title="Chip-8 Emulator"
                      Description="Placeholder project description for the Chip-8 emulator."
                      ImageSrc="images/chip-8.gif" />

        <ProjectLinksBar Links="@LinkChips" Tags="@TechChips" />

        <ProjectSummaryCard Title="Project Summary and Motivation"
                            Paragraphs="@SummaryParagraphs"
                            NextStep="@NextStep" />

        <ProjectFeaturesGrid Features="@Features" />

        <ProjectChallenges Title="Challenges"
                           IntroText="@ChallengesIntro"
                           Challenges="@Challenges" />
        
        <ProjectShowcaseGrid ShowcaseItems="@ShowcaseItems" />

        <GithubFooter Href="@RepositoryUrl" />

        <ProjectSources Sources="@Sources" />
    </MudStack>
</MudContainer>
