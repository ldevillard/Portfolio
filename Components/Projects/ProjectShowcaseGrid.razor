<MudPaper Class="pa-6 rounded-lg" Elevation="0" Outlined="true">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h5">@Title</MudText>
        <MudDivider/>

        <MudGrid Spacing="2">
            @foreach (ProjectShowcase showcase in ShowcaseItems)
            {
                <MudItem xs="12" md="6">
                    <MudStack Spacing="2" Class="project-visual-card">
                        <img src="@showcase.ImageSrc"
                             alt="@showcase.Title"
                             class="project-image" />
                        <MudText Typo="Typo.h6">@showcase.Title</MudText>
                        <MudText Typo="Typo.body2">@showcase.Description</MudText>
                    </MudStack>
                </MudItem>
            }
        </MudGrid>
    </MudStack>
</MudPaper>
