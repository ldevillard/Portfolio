<MudLink Href="@Href" Underline="Underline.Hover" Target="_blank">
    <MudPaper Class="px-4 py-3 rounded-lg" Elevation="0" Outlined="true">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1" AlignItems="AlignItems.Start">
                @if (Categories.Count > 0)
                {
                    <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;">
                        @foreach (string category in Categories)
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="Color.Secondary">
                                @category
                            </MudChip>
                        }
                    </MudStack>
                }

                <MudText Typo="Typo.subtitle2">@Title</MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                <img src="@ImageSrc"
                     alt="@Title"
                     width="120"
                     height="56"
                     style="object-fit: cover; border-radius: 8px;" />
                <MudIcon Icon="@Icons.Material.Filled.ArrowOutward" />
            </MudStack>
        </MudStack>
    </MudPaper>
</MudLink>
