<div class="section-divider">
    <span class="section-divider-line" aria-hidden="true"></span>
    <div class="section-divider-content">
        <span class="section-divider-label">@Label</span>

        @if (!string.IsNullOrWhiteSpace(Caption))
        {
            <span class="section-divider-caption">@Caption</span>
        }
    </div>
    <span class="section-divider-line" aria-hidden="true"></span>
</div>
