@if (string.IsNullOrWhiteSpace(Href))
{
    <MudPaper Class="pa-4 rounded-lg" Elevation="0" Outlined="true">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="3">
            <MudStack Spacing="1" AlignItems="AlignItems.Start">
                @if (!string.IsNullOrWhiteSpace(Category))
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="Variant.Outlined"
                             Color="Color.Secondary">
                        @Category
                    </MudChip>
                }

                <MudText Typo="Typo.h6">@Title</MudText>
                <MudText Typo="Typo.body2">
                    @Description
                </MudText>
            </MudStack>

            <img src="@ImageSrc"
                 alt="@Title"
                 width="180"
                 height="104"
                 style="object-fit: cover; border-radius: 8px;" />
        </MudStack>
    </MudPaper>
}
else
{
    <a href="@Href"
       target="_blank"
       rel="noopener noreferrer">
        <MudPaper Class="pa-4 rounded-lg" Elevation="0" Outlined="true">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="3">
                <MudStack Spacing="1" AlignItems="AlignItems.Start">
                    @if (!string.IsNullOrWhiteSpace(Category))
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="Color.Secondary">
                            @Category
                        </MudChip>
                    }

                    <MudText Typo="Typo.h6">@Title</MudText>
                    <MudText Typo="Typo.body2">
                        @Description
                    </MudText>
                </MudStack>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <img src="@ImageSrc"
                         alt="@Title"
                         width="180"
                         height="104"
                         style="object-fit: cover; border-radius: 8px;" />
                    <MudIcon Icon="@Icons.Material.Filled.ArrowOutward" Color="Color.Secondary" />
                </MudStack>
            </MudStack>
        </MudPaper>
    </a>
}
