                    Developed and optimized performance-critical real-time simulation features on CPU and GPU
                </MudText>
            </div>

            <div class="professional-highlight-item">
                <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Warning" Size="Size.Small" Class="professional-highlight-icon" />
                <MudText Typo="Typo.body2" Class="professional-highlight-text">
