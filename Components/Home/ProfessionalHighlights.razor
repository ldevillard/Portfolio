    <MudDivider Class="mt-2"/>
    <MudStack Spacing="3" Class="mt-4">
        <div class="professional-highlights-grid">
            <div class="professional-highlight-item">
                <MudIcon Icon="@Icons.Material.Filled.Memory" Color="Color.Warning" Size="Size.Small" Class="professional-highlight-icon" />
                <MudText Typo="Typo.body2" Class="professional-highlight-text">
                    Contributed to low-level C++ development on large-scale and legacy codebases, including proprietary game engine systems
                </MudText>
            </div>

            <div class="professional-highlight-item">
                <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Warning" Size="Size.Small" Class="professional-highlight-icon" />
