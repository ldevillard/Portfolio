                    Built internal UI tools using Unreal Engine, WPF (C#), and Qt (C++)
                </MudText>
            </div>

            <div class="professional-highlight-item">
                <MudIcon Icon="@Icons.Material.Filled.DeveloperBoard" Color="Color.Warning" Size="Size.Small" Class="professional-highlight-icon" />
                <MudText Typo="Typo.body2" Class="professional-highlight-text">
